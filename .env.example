# Gemini AI API Key
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (required) — Auth, Postgres, Storage, sync queue target
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Storage bucket for audit yield photos (default: audit-photos)
# Create bucket in Dashboard → Storage; allow authenticated uploads to folder prefix.
# VITE_SUPABASE_AUDIT_PHOTOS_BUCKET=audit-photos

# Optional: Enable debug mode
# VITE_DEBUG=true

# Optional: Analytics/Monitoring
# VITE_SENTRY_DSN=your_sentry_dsn_here

# SECURITY WARNING:
# NEVER put SUPABASE_SERVICE_ROLE_KEY in this file or any frontend .env.
# It is a backend-only secret that grants full admin access to your database.
# Use it only in server-side code, edge functions, or CI secrets.
